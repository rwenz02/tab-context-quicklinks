{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
    "manifestVersion": "1.26",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Rick Wenz",
        "websiteUrl": "https://<your-website-url>",
        "privacyUrl": "https://<your-privacy-url>",
        "termsOfUseUrl": "https://<your-terms-of-use-url>"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Teams QuickLinks",
        "full": "Teams QuickLinks"
    },
    "description": {
        "short": "Context-aware quick links for your Teams channels and tabs.",
        "full": "A lightweight Microsoft Teams Tab app that displays context-aware quick links based on the current team and channel. Links are resolved from a static JSON configuration, supporting team-level, channel-level, and default fallback sets. Users can search, pin, and unpin links — all without a backend or database."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "bots": [],
    "composeExtensions": [],
    "staticTabs": [
        {
            "entityId": "index0",
            "name": "Home",
            "contentUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "websiteUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "scopes": [
                "personal",
                "groupChat",
                "team"
            ]
        }
    ],
    "configurableTabs": [
        {
            "configurationUrl": "${{TAB_ENDPOINT}}/tabs/home",
            "canUpdateConfiguration": false,
            "scopes": [
                "team",
                "groupChat"
            ]
        }
    ],
    "permissions": [
        "identity"
    ],
    "validDomains": [
        "${{TAB_DOMAIN}}"
    ]
}